generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  credits   Int      @default(100)
  plan      String   @default("free") // free, pro, enterprise
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chats     Chat[]
  favorites Favorite[]
}

model AgentSkill {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  category    String   // marketing, research, strategy, legal, academic, development, writing, design
  prompt      String   // system prompt for the agent
  isBuiltIn   Boolean  @default(true)
  usageCount  Int      @default(0)
  rating      Float    @default(4.5)
  tags        String   @default("") // comma separated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  favorites   Favorite[]
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Chat")
  agentId   String?  // which agent skill is being used
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String   // user, assistant, system
  content   String
  agentId   String?
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String     @id @default(cuid())
  userId    String
  skillId   String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     AgentSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}
